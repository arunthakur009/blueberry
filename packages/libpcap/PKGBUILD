# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libpcap
pkgver=1.10.5
pkgrel=1
pkgdesc='Portable packet capture library'
arch=('x86_64')
url='https://www.tcpdump.org/'
license=('BSD-3-Clause')
depends=('glibc')
provides=('libpcap.so')
source=("https://www.tcpdump.org/release/libpcap-$pkgver.tar.xz")
sha256sums=('84fa89ac6d303028c1c5b754abff77224f45eca0a94eb1a34ff0aa9ceece3925')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --without-dbus --without-libnl
  make
}
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
