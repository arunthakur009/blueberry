# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=e2fsprogs
pkgver=1.47.2
pkgrel=1
pkgdesc='Ext2/3/4 filesystem utilities (mkfs.ext4, e2fsck) + libuuid/libblkid'
arch=('x86_64')
url='https://e2fsprogs.sourceforge.net/'
license=('GPL-2.0-only' 'LGPL-2.0-only' 'MIT')
depends=('glibc')
provides=('libuuid.so' 'libblkid.so' 'libe2p.so' 'libext2fs.so' 'libcom_err.so' 'libss.so')
source=("https://mirrors.kernel.org/pub/linux/kernel/people/tytso/e2fsprogs/v$pkgver/e2fsprogs-$pkgver.tar.xz")
sha256sums=('08242e64ca0e8194d9c1caad49762b19209a06318199b63ce74ae4ef2d74e63c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --with-root-prefix=/usr --enable-elf-shlibs \
    --enable-libuuid --enable-libblkid --disable-fsck --disable-uuidd
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
