# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# D-Bus — the system message bus. Required by systemd (org.freedesktop.systemd1)
# and most desktop/service IPC. Built without its own systemd unit hookup at
# first (systemd is packaged separately); the bus runs fine standalone.
pkgname=dbus
pkgver=1.16.0
pkgrel=1
pkgdesc='Freedesktop.org message bus system (libdbus + dbus-daemon)'
arch=('x86_64')
url='https://www.freedesktop.org/wiki/Software/dbus/'
license=('GPL-2.0-or-later OR AFL-2.1')
depends=('glibc' 'expat')
makedepends=('meson' 'ninja' 'pkgconf')
source=("https://dbus.freedesktop.org/releases/dbus/dbus-$pkgver.tar.xz")
sha256sums=('9f8ca5eb51cbe09951aec8624b86c292990ae2428b41b856e2bed17ec65c8849')

build() {
  cd "$pkgname-$pkgver"
  meson setup build --prefix=/usr --buildtype=release \
    -Dsystemd=disabled -Dselinux=disabled -Dapparmor=disabled \
    -Dx11_autolaunch=disabled -Ddoxygen_docs=disabled -Dducktype_docs=disabled \
    -Dxml_docs=disabled -Dmodular_tests=disabled
  meson compile -C build
}

package() {
  cd "$pkgname-$pkgver"
  meson install -C build --destdir="$pkgdir"
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
