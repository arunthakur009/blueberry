#!/bin/sh
# blueberry-grub-mkconfig — regenerate /boot/grub/grub.cfg for an installed
# Blueberry system. Produces a config byte-compatible with the one the installer
# writes (src/installer/src/boot.rs::write_grub_cfg): the root filesystem is
# located by UUID with `search --fs-uuid`, the kernel and initramfs live on that
# root fs under /boot, and an optional cryptdevice= prefix handles LUKS. Run by
# the linux package's post-install/upgrade hook (blueberry-kernel-hook) so a
# `bpm upgrade` that pulls a new kernel stays bootable — and adds a fallback menu
# entry for the previous kernel (/boot/vmlinuz.old) when one is stashed.
set -eu

BOOT=${BOOT:-/boot}
CFG="$BOOT/grub/grub.cfg"

[ -f "$BOOT/vmlinuz" ] || { echo "grub-mkconfig: no $BOOT/vmlinuz" >&2; exit 1; }

# Root spec exactly as the installer recorded it in /etc/fstab: "UUID=<uuid>" for
# plain/LVM roots, or "/dev/mapper/cryptroot" for LUKS. This is what goes on the
# kernel command line as root=.
rootspec=$(awk '$1 !~ /^#/ && $2 == "/" { print $1; exit }' /etc/fstab 2>/dev/null || true)
[ -n "$rootspec" ] || { echo "grub-mkconfig: cannot find root in /etc/fstab" >&2; exit 1; }

# The fs UUID grub uses to *find* the disk (search --fs-uuid). If fstab already
# names the root by UUID, reuse it; otherwise resolve the backing device.
case "$rootspec" in
    UUID=*) rootuuid=${rootspec#UUID=} ;;
    *)      rootuuid=$(blkid -s UUID -o value "$rootspec" 2>/dev/null || findmnt -no UUID / 2>/dev/null || true) ;;
esac
[ -n "$rootuuid" ] || { echo "grub-mkconfig: cannot resolve root fs UUID" >&2; exit 1; }

# LUKS: if root is the mapper and crypttab documents it, pass cryptdevice=.
cryptarg=""
if [ -f /etc/crypttab ] && [ "$rootspec" = "/dev/mapper/cryptroot" ]; then
    src=$(awk '$1 !~ /^#/ && $1 == "cryptroot" { print $2; exit }' /etc/crypttab || true)
    [ -n "$src" ] && cryptarg="cryptdevice=$src:cryptroot "
fi

mkdir -p "$BOOT/grub"
{
    printf 'set timeout=3\n'
    printf 'insmod all_video\n'
    printf 'insmod lvm\n'
    printf "menuentry 'Blueberry Linux' {\n"
    printf '    search --no-floppy --fs-uuid --set=root %s\n' "$rootuuid"
    printf '    linux /boot/vmlinuz %sroot=%s rw console=tty0 console=ttyS0,115200\n' \
        "$cryptarg" "$rootspec"
    [ -f "$BOOT/initramfs.cpio.zst" ] && printf '    initrd /boot/initramfs.cpio.zst\n'
    printf '}\n'
    # Fallback: the previous kernel, stashed as vmlinuz.old by blueberry-kernel-hook
    # on upgrade. Same initramfs (the kernel is monolithic — no loadable modules),
    # so it boots the old kernel too.
    if [ -f "$BOOT/vmlinuz.old" ]; then
        printf "menuentry 'Blueberry Linux (fallback \xe2\x80\x94 previous kernel)' {\n"
        printf '    search --no-floppy --fs-uuid --set=root %s\n' "$rootuuid"
        printf '    linux /boot/vmlinuz.old %sroot=%s rw console=tty0 console=ttyS0,115200\n' \
            "$cryptarg" "$rootspec"
        [ -f "$BOOT/initramfs.cpio.zst" ] && printf '    initrd /boot/initramfs.cpio.zst\n'
        printf '}\n'
    fi
} > "$CFG"

echo "grub-mkconfig: wrote $CFG (root=$rootspec uuid=$rootuuid)"
