#!/bin/sh
# blueberry-kernel-hook — make a freshly installed/upgraded kernel bootable.
# Called from the linux package's post_install/post_upgrade scriptlets (see
# packages/linux/bpm.toml [scripts]). The package ships the kernel as a versioned
# file (/boot/vmlinuz-<ver>-blueberry); this promotes the newest one to the
# stable /boot/vmlinuz path the bootloader points at, keeping the previous kernel
# as /boot/vmlinuz.old for a fallback menu entry, then regenerates grub.cfg.
#
# bpm runs scriptlets *chrooted* into the target (see pkg.rs::run_root_sh), so all
# paths here are absolute and resolve inside the target root — no BPM_ROOT.
set -eu

BOOT=/boot

# Newest versioned kernel this package installed (version-sort the dotted names).
new=$(ls -1 "$BOOT"/vmlinuz-*-blueberry 2>/dev/null | sort -V | tail -n1 || true)
[ -n "$new" ] || exit 0   # nothing versioned to promote (e.g. artifact-only image)

# Stash the currently-booting kernel as the fallback, unless it already IS the
# new one (idempotent re-runs) or does not exist yet (fresh install).
if [ -e "$BOOT/vmlinuz" ] && ! cmp -s "$BOOT/vmlinuz" "$new"; then
    cp -f "$BOOT/vmlinuz" "$BOOT/vmlinuz.old"
fi
cp -f "$new" "$BOOT/vmlinuz"

# Regenerate the bootloader config on a real installed system (has /etc/fstab and
# the grub helper). Skipped in build/staging roots where there is no fstab yet.
if [ -f /etc/fstab ] && command -v blueberry-grub-mkconfig >/dev/null 2>&1; then
    blueberry-grub-mkconfig || echo "kernel-hook: grub-mkconfig failed (kernel still at $BOOT/vmlinuz)" >&2
fi

echo "kernel-hook: /boot/vmlinuz -> $(basename "$new")"
