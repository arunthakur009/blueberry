# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=chrony
pkgver=4.6.1
pkgrel=1
pkgdesc='Versatile implementation of the Network Time Protocol (NTP)'
arch=('x86_64')
url='https://chrony-project.org/'
license=('GPL-2.0-only')
depends=('glibc' 'libcap')
source=("https://chrony-project.org/releases/chrony-$pkgver.tar.gz")
sha256sums=('571ff73fbf0ae3097f0604eca2e00b1d8bb2e91affe1a3494785ff21d6199c5c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --without-readline --without-nettle \
    --without-gnutls --without-nss --without-seccomp --disable-sechash
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
