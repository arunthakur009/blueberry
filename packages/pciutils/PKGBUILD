# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=pciutils
pkgver=3.13.0
pkgrel=1
pkgdesc='PCI bus configuration space access library and tools (lspci, setpci)'
arch=('x86_64')
url='https://mj.ucw.cz/sw/pciutils/'
license=('GPL-2.0-or-later')
depends=('glibc' 'zlib')
provides=('libpci.so')
source=("https://mirrors.kernel.org/pub/software/utils/pciutils/pciutils-$pkgver.tar.xz")
sha256sums=('77f11f78298502634d1af50308f15a5788629f6cf45cba376f5009aea4cb4926')
build() {
  cd "$pkgname-$pkgver"
  make PREFIX=/usr SHARED=yes ZLIB=yes
}
package() {
  cd "$pkgname-$pkgver"
  make PREFIX=/usr DESTDIR="$pkgdir" SHARED=yes ZLIB=yes install install-lib
}
