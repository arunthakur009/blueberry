name=linux-headers
version=7.0
release=1
description="Linux kernel headers for userspace"
url="https://kernel.org/"
license="GPL-2.0-only WITH Linux-syscall-note"
arch=("x86_64" "aarch64" "riscv64")
depends=()
makedepends=()
source=("https://cdn.kernel.org/pub/linux/kernel/v7.x/linux-$version.tar.xz")
checksums=("SKIP")
packager="Blueberry Maintainers <maintainers@blueberry.linux>"

build() {
    cd "linux-$version"
    make mrproper
    make ARCH=x86_64 headers_check
}

package() {
    cd "linux-$version"
    make ARCH=x86_64 \
         INSTALL_HDR_PATH="$pkgdir/usr" \
         headers_install

    # Remove unwanted files
    find "$pkgdir/usr/include" \( -name .install -o -name ..install.cmd \) -delete
}
