# Make.config — machine-local build configuration
# Copy this file to Make.local and edit it. Make.local is .gitignored.
# GNUmakefile includes Make.local if present, then falls back to these defaults.

# ── Architecture ──────────────────────────────────────────────────────────────
ARCH          ?= x86_64
# Supported: x86_64, aarch64, riscv64

# ── Toolchain ─────────────────────────────────────────────────────────────────
# Cross-compilation target triple. Set empty to use native host compiler.
# CROSS_COMPILE ?= x86_64-linux-musl-
CROSS_COMPILE ?=

CC            = $(CROSS_COMPILE)gcc
CXX           = $(CROSS_COMPILE)g++
AR            = $(CROSS_COMPILE)ar
STRIP         = $(CROSS_COMPILE)strip
OBJCOPY       = $(CROSS_COMPILE)objcopy

# musl-gcc wrapper (used for building musl-linked binaries on a glibc host)
MUSL_CC       ?= musl-gcc

# ── Parallel jobs ─────────────────────────────────────────────────────────────
JOBS          ?= $(shell nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)

# ── Source versions ───────────────────────────────────────────────────────────
LINUX_VERSION    ?= 7.0
MUSL_VERSION     ?= 1.2.5
BUSYBOX_VERSION  ?= 1.36.1
RUNIT_VERSION    ?= 2.1.2
OPENSSL_VERSION  ?= 3.3.1
ZLIB_VERSION     ?= 1.3.1

# ── Directories ───────────────────────────────────────────────────────────────
# All build artefacts live under OBJDIR — never in the source tree.
# Default: sibling directory ../blueberry-build, fully outside the source tree.
# Override in Make.local: OBJDIR ?= /path/to/your/build/dir
TOPDIR  := $(CURDIR)
OBJDIR  ?= $(abspath $(TOPDIR)/../blueberry-build)
DESTDIR ?= $(OBJDIR)/rootfs

# ── Compiler flags ────────────────────────────────────────────────────────────
CFLAGS   ?= -Os -pipe -fstack-protector-strong
CXXFLAGS ?= $(CFLAGS)
LDFLAGS  ?= -Wl,-z,relro,-z,now

# ── Go toolchain ──────────────────────────────────────────────────────────────
GO       ?= go
GOFLAGS  ?= -trimpath
GO_LDFLAGS ?= -s -w

# ── Kernel options ────────────────────────────────────────────────────────────
KERNEL_LOCALVERSION ?= -blueberry

# ── Package repository ────────────────────────────────────────────────────────
REPO_URL     ?= https://repo.blueberry.linux/packages/$(ARCH)
REPO_SIGN    ?= 1   # set to 0 to disable package signing
MINISIGN_KEY ?=     # path to minisign secret key
